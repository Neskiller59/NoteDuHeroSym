{% extends 'base.html.twig' %}

{% block title %}
    Inventaire de {{ hero.name }}
{% endblock %}

{% block body %}

<div class="inventory-wrapper container mt-4"
     style="max-width:1400px; width:100%;">

    {# =========================
       TOP BAR
       ========================= #}

    <div class="d-flex justify-content-between align-items-center mb-4 p-3 rounded shadow-sm"
         style="background-color:#1e1e2f; color:#fff;">

        <h1 style="margin:0;">
            🎒 Inventaire de {{ hero.name }}
        </h1>

        <div class="d-flex align-items-center gap-3">

            {# =========================
               GOLD — autosave AJAX
               L'utilisateur modifie la valeur,
               elle est sauvegardée automatiquement
               après 800 ms d'inactivité (debounce).
               ========================= #}

            <div class="d-flex align-items-center p-2 rounded"
                 style="background-color:#3a3a5c; gap:8px;">

                <label class="text-warning mb-0" for="goldInput">
                    💰 Or
                </label>

                <input type="number"
                       id="goldInput"
                       name="gold"
                       value="{{ hero.gold }}"
                       min="0"
                       class="form-control form-control-sm"
                       style="width:100px;">

                {# Indicateur de statut (vide au départ) #}
                <span id="goldStatus" style="font-size:0.8rem; min-width:60px;"></span>

            </div>

            {# =========================
               NEW ITEM BUTTON
               ========================= #}

            <a href="{{ path('inventory_new') }}"
               class="btn btn-primary btn-sm">
                ➕ Ajouter un objet
            </a>

        </div>

    </div>

    {# =========================
       FLASH MESSAGES
       ========================= #}

    {% for label, messages in app.flashes %}
        {% for message in messages %}
            <div class="alert alert-{{ label == 'error' ? 'danger' : label }}
                        alert-dismissible fade show"
                 role="alert">

                {{ message }}

                <button type="button"
                        class="btn-close"
                        data-bs-dismiss="alert">
                </button>

            </div>
        {% endfor %}
    {% endfor %}

    {# =========================
       INVENTORY ITEMS
       ========================= #}

    <div class="d-flex flex-wrap"
         style="gap:10px; width:100%;">

        {% if items is not empty %}

            {% for item in items %}

                <div style="flex:1 1 calc(25% - 10px); min-width:220px;">

                    <div class="card shadow-sm h-100 inventory-card">

                        <div class="card-body d-flex flex-column justify-content-between p-3">

                            <div>

                                <h5 class="card-title text-warning mb-2">
                                    {{ item.name }}
                                </h5>

                                <p class="mb-2">
                                    <strong>Description :</strong>
                                    {{ item.description|length > 100
                                        ? item.description|slice(0,100) ~ '...'
                                        : item.description }}
                                </p>

                                {% if item.additionalInfo %}
                                    <p class="small text-secondary">
                                        <strong>Infos :</strong>
                                        {{ item.additionalInfo|length > 50
                                            ? item.additionalInfo|slice(0,50) ~ '...'
                                            : item.additionalInfo }}
                                    </p>
                                {% endif %}

                            </div>

                            <div class="mt-3 d-flex justify-content-end gap-2">

                                <a href="{{ path('inventory_edit', {
                                    id: item.id
                                }) }}"
                                   class="btn btn-warning btn-sm">
                                    ✏️
                                </a>

                                <form method="POST"
                                      action="{{ path('inventory_delete', {
                                          id: item.id
                                      }) }}"
                                      onsubmit="return confirm('Supprimer cet objet ?');">

                                    <input type="hidden"
                                           name="_token"
                                           value="{{ csrf_token('delete' ~ item.id) }}">

                                    <button type="submit"
                                            class="btn btn-danger btn-sm">
                                        🗑️
                                    </button>

                                </form>

                            </div>

                        </div>

                    </div>

                </div>

            {% endfor %}

        {% else %}

            <div class="w-100 text-center mt-5">

                <h3 class="text-light">
                    Aucun objet dans l'inventaire
                </h3>

                <p class="text-secondary">
                    Ajoutez votre premier équipement.
                </p>

            </div>

        {% endif %}

    </div>

</div>

{# =========================
   AUTOSAVE GOLD — JavaScript
   - Debounce 800 ms : sauvegarde 800 ms
     après le dernier changement
   - Feedback visuel : ✅ Sauvegardé / ❌ Erreur
   - Champ 'gold' correspond à ce que lit
     le controller (request->get('gold'))
   ========================= #}

<script>
(function () {

    const input    = document.getElementById('goldInput');
    const status   = document.getElementById('goldStatus');
    const endpoint = '{{ path('inventory_update_gold') }}';

    let timer = null;

    function showStatus(msg, color) {
        status.textContent = msg;
        status.style.color  = color;
    }

    function saveGold(value) {

        showStatus('⏳ …', '#aaa');

        const body = new URLSearchParams({ gold: value });

        fetch(endpoint, {
            method  : 'POST',
            headers : { 'Content-Type': 'application/x-www-form-urlencoded' },
            body    : body
        })
        .then(function (res) {

            if (!res.ok) {
                throw new Error('Réponse serveur ' + res.status);
            }

            return res.json();
        })
        .then(function (data) {

            // Le controller renvoie { gold: <valeur_sauvegardée> }
            input.value = data.gold;
            showStatus('✅ Sauvegardé', '#4caf50');

            // Efface le message après 2 s
            setTimeout(function () {
                status.textContent = '';
            }, 2000);
        })
        .catch(function () {
            showStatus('❌ Erreur', '#f44336');
        });
    }

    // Déclenche la sauvegarde 800 ms après le dernier changement
    input.addEventListener('input', function () {

        clearTimeout(timer);

        showStatus('…', '#aaa');

        timer = setTimeout(function () {
            saveGold(input.value);
        }, 800);
    });

})();
</script>

