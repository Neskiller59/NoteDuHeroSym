{% extends 'base.html.twig' %}

{% block title %}Quêtes de {{ hero.name }}{% endblock %}

{% block body %}
<div class="container mt-4" style="max-width:1100px;">

    {# =========================
       HEADER
       ========================= #}
    <div class="quest-header shadow-lg mb-4">

        <div>
            <h1 class="mb-1">
                📜 Quêtes de {{ hero.name }}
            </h1>

            <div class="text-light opacity-75">
                Gérez les aventures de votre héros
            </div>
        </div>

        <a href="{{ path('quest_new', { heroId: hero.id }) }}"
           class="btn btn-success btn-lg">
            ➕ Nouvelle quête
        </a>

    </div>

    {# =========================
       FLASH MESSAGES
       ========================= #}
    {% for label, messages in app.flashes %}
        {% for message in messages %}

            <div class="alert alert-{{ label == 'error' ? 'danger' : label }}
                        alert-dismissible fade show">

                {{ message }}

                <button type="button"
                        class="btn-close"
                        data-bs-dismiss="alert">
                </button>

            </div>

        {% endfor %}
    {% endfor %}

    {# =========================
       QUEST LIST
       ========================= #}
    {% if quests|length > 0 %}

        <div class="row g-4">

            {% for quest in quests %}

                <div class="col-lg-6">

                    <div class="quest-card h-100">

                        <div class="quest-card-body">

                            <div class="d-flex justify-content-between align-items-start mb-3">

                                <h4 class="quest-title">
                                    {{ quest.name }}
                                </h4>

                                <div class="d-flex gap-2">

                                    {# EDIT #}
                                    <a href="{{ path('quest_edit', {
                                        heroId: hero.id,
                                        id: quest.id
                                    }) }}"
                                       class="btn btn-warning btn-sm">
                                        ✏️
                                    </a>

                                    {# DELETE #}
                                    <form method="post"
                                          action="{{ path('quest_delete', {
                                              heroId: hero.id,
                                              id: quest.id
                                          }) }}"
                                          onsubmit="return confirm('Supprimer cette quête ?');">

                                        <input type="hidden"
                                               name="_token"
                                               value="{{ csrf_token('delete' ~ quest.id) }}">

                                        <button type="submit"
                                                class="btn btn-danger btn-sm">
                                            🗑️
                                        </button>

                                    </form>

                                </div>

                            </div>

                            <div class="quest-section">

                                <div class="quest-label">
                                     Objectif
                                </div>

                                <p>
                                    {{ quest.objectif ?: 'Aucun objectif.' }}
                                </p>

                            </div>

                            {% if quest.information %}

                                <div class="quest-section">

                                    <div class="quest-label">
                                         Informations
                                    </div>

                                    <p>
                                        {{ quest.information }}
                                    </p>

                                </div>

                            {% endif %}

                            {% if quest.origine %}

                                <div class="quest-section">

                                    <div class="quest-label">
                                         Origine
                                    </div>

                                    <p>
                                        {{ quest.origine }}
                                    </p>

                                </div>

                            {% endif %}

                        </div>

                    </div>

                </div>

            {% endfor %}

        </div>

    {% else %}

        <div class="empty-quest shadow">

            <h3 class="mb-3">
                Aucune quête active
            </h3>

            <p class="mb-4 opacity-75">
                Ce héros n'a encore aucune aventure.
            </p>

            <a href="{{ path('quest_new', { heroId: hero.id }) }}"
               class="btn btn-success">
                ➕ Créer la première quête
            </a>

        </div>

    {% endif %}

</div>

<style>

body{
    background:#151521;
    color:white;
}

/* =========================
   HEADER
========================= */

.quest-header{
    background:linear-gradient(145deg,#23233a,#181826);
    border-radius:18px;
    padding:25px;
    display:flex;
    justify-content:space-between;
    align-items:center;
    border:1px solid rgba(255,255,255,0.05);
}

/* =========================
   CARD
========================= */

.quest-card{
    background:linear-gradient(145deg,#23233a,#181826);
    border-radius:18px;
    overflow:hidden;
    height:100%;
    border:1px solid rgba(255,255,255,0.05);
    transition:0.25s;
    box-shadow:0 0 15px rgba(0,0,0,0.3);
}

.quest-card:hover{
    transform:translateY(-4px);
    box-shadow:0 0 25px rgba(255,215,0,0.12);
}

.quest-card-body{
    padding:22px;
}

.quest-title{
    color:#ffd700;
    margin:0;
}

/* =========================
   QUEST SECTION
========================= */

.quest-section{
    margin-bottom:18px;
}

.quest-label{
    color:#ffd700;
    font-weight:bold;
    margin-bottom:5px;
}

/* =========================
   EMPTY
========================= */

.empty-quest{
    background:linear-gradient(145deg,#23233a,#181826);
    border-radius:18px;
    padding:50px;
    text-align:center;
}

/* =========================
   BUTTONS
========================= */

.btn-warning{
    background:#ffd700;
    border:none;
    color:#000;
}

.btn-warning:hover{
    background:#ffcc00;
    color:#000;
}

.btn-danger:hover{
    background:#ff4d4d;
}

.btn-success{
    font-weight:bold;
}

</style>

{% endblock %}