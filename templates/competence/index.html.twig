{% extends 'base.html.twig' %}

{% block title %}Compétences{% endblock %}

{% block body %}

{% set heroId = app.session.get('active_hero_id') %}

<div class="container mt-5" style="max-width:1000px;">

    {# =========================
       HEADER
       ========================= #}
    <div class="d-flex justify-content-between align-items-center mb-4">

        <h1 class="h3 fw-bold">
            Compétences
        </h1>

        {% if heroId %}

            <a href="{{ path('competence_new') }}"
               class="btn btn-outline-primary">
                ➕ Nouvelle compétence
            </a>

        {% else %}

            <span class="text-muted">
                Sélectionnez un héros
            </span>

        {% endif %}

    </div>

    {# =========================
       EMPTY STATE
       ========================= #}
    {% if competences is empty %}

        <div class="alert alert-secondary">
            Aucune compétence trouvée pour ce héros.
        </div>

    {% else %}

        <div class="table-responsive">

            <table class="table table-striped table-hover align-middle">

                <thead class="table-dark">
                    <tr>
                        <th>Nom</th>
                        <th>Description</th>
                        <th>Effet</th>
                        <th>Origine</th>
                        <th class="text-end">Actions</th>
                    </tr>
                </thead>

                <tbody>

                    {% for competence in competences %}

                        <tr>

                            <td>{{ competence.name }}</td>

                            <td>
                                {{ competence.description
                                    ? (competence.description|length > 50
                                        ? competence.description|slice(0, 50) ~ '...'
                                        : competence.description)
                                    : ''
                                }}
                            </td>

                            <td>{{ competence.effet }}</td>

                            <td>{{ competence.origine }}</td>

                            <td class="text-end">

                                <a href="{{ path('competence_edit', { id: competence.id }) }}"
                                   class="btn btn-sm btn-outline-secondary me-1">
                                    ✏️
                                </a>

                                <form method="post"
                                      action="{{ path('competence_delete', { id: competence.id }) }}"
                                      style="display:inline;"
                                      onsubmit="return confirm('Supprimer cette compétence ?');">

                                    <input type="hidden"
                                           name="_token"
                                           value="{{ csrf_token('delete' ~ competence.id) }}">

                                    <button class="btn btn-sm btn-outline-danger">
                                        🗑
                                    </button>

                                </form>

                            </td>

                        </tr>

                    {% endfor %}

                </tbody>

            </table>

        </div>

    {% endif %}

    {# =========================
       FLASH MESSAGES
       ========================= #}
    {% for label, messages in app.flashes %}

        {% for message in messages %}

            <div class="alert alert-{{ label }} alert-dismissible fade show mt-3">

                {{ message }}

                <button type="button" class="btn-close" data-bs-dismiss="alert"></button>

            </div>

        {% endfor %}

    {% endfor %}

</div>

{% endblock %}