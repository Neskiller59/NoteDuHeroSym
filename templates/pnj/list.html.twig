{% extends 'base.html.twig' %}

{% block title %}PNJ de {{ hero.name }}{% endblock %}

{% block body %}

<div class="container mt-4" style="max-width:900px;">

    {# HEADER #}
    <div class="d-flex justify-content-between align-items-center mb-4">

        <h1 class="h2">PNJ de {{ hero.name }}</h1>

        <a href="{{ path('pnj_new') }}" class="btn btn-success">
            ➕ Nouveau PNJ
        </a>

    </div>

    {# EMPTY STATE #}
    {% if pnjs is empty %}

        <div class="alert text-center">
            Aucun PNJ trouvé pour ce héros.
        </div>

    {% else %}

        {% for pnj in pnjs %}

            <div class="card mb-3 shadow-sm"
                 style="background-color:#2a2a3f; color:#fff;">

                <div class="card-body d-flex justify-content-between">

                    {# LEFT CONTENT #}
                    <div>

                        <h3 class="card-title">
                            {{ pnj.name }}
                        </h3>

                        <p class="mb-1">
                            <strong>Description :</strong>
                            {{ pnj.description }}
                        </p>

                        {% if pnj.information %}
                            <p class="mb-1">
                                <strong>Informations :</strong>
                                {{ pnj.information }}
                            </p>
                        {% endif %}

                        {% if pnj.localisation %}
                            <p class="mb-1">
                                <strong>Localisation :</strong>
                                {{ pnj.localisation }}
                            </p>
                        {% endif %}

                        {% if pnj.personnalite %}
                            <p class="mb-1">
                                <strong>Personnalité :</strong>
                                {{ pnj.personnalite }}
                            </p>
                        {% endif %}

                        {% if pnj.competence %}
                            <p class="mb-1">
                                <strong>Compétence :</strong>
                                {{ pnj.competence }}
                            </p>
                        {% endif %}

                    </div>

                    {# ACTIONS #}
                    <div class="d-flex align-items-start gap-2">

                        <a href="{{ path('pnj_edit', { id: pnj.id }) }}"
                           class="btn btn-warning btn-sm">
                            ✏️
                        </a>

                        <form method="post"
                              action="{{ path('pnj_delete', { id: pnj.id }) }}"
                              onsubmit="return confirm('Supprimer ce PNJ ?');">

                            <input type="hidden"
                                   name="_token"
                                   value="{{ csrf_token('delete' ~ pnj.id) }}">

                            <button class="btn btn-danger btn-sm">
                                🗑️
                            </button>

                        </form>

                    </div>

                </div>

            </div>

        {% endfor %}

    {% endif %}

</div>

{% endblock %}