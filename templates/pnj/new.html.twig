{% extends 'base.html.twig' %}

{% block title %}Nouveau PNJ{% endblock %}

{% block body %}

<div class="container mt-4" style="max-width:700px;">

    <h1 class="mb-4">🧙 Nouveau PNJ pour {{ hero.name }}</h1>

    <form method="post">

        <div class="mb-3">
            <label>Nom</label>
            <input type="text" name="name" class="form-control" required>
        </div>

        <div class="mb-3">
            <label>Description</label>
            <textarea name="description" class="form-control"></textarea>
        </div>

        <div class="mb-3">
            <label>Localisation</label>
            <input type="text" name="localisation" class="form-control">
        </div>

        <div class="mb-3">
            <label>Personnalité</label>
            <textarea name="personnalite" class="form-control"></textarea>
        </div>

        <div class="mb-3">
            <label>Compétence</label>
            <textarea name="competence" class="form-control"></textarea>
        </div>

        <div class="mb-3">
            <label>Informations (notes)</label>
            <textarea name="information" class="form-control"></textarea>
        </div>

        <button class="btn btn-success">
            ➕ Créer PNJ
        </button>

        <a href="{{ path('pnj_list') }}" class="btn btn-secondary">
            Annuler
        </a>

    </form>

</div>

{% endblock %}