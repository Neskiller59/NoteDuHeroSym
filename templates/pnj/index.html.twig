```twig
{% extends 'base.html.twig' %}

{% block title %}
    PNJ de {{ hero.name }}
{% endblock %}

{% block body %}

<div class="rpg-container container mt-5">

    {# =========================
       HEADER
       ========================= #}

    <div class="d-flex justify-content-between align-items-center mb-4">

        <h1 class="rpg-title">
            🧙 PNJ de {{ hero.name }}
        </h1>

        <a href="{{ path('pnj_new') }}"
           class="btn btn-warning">

            ➕ Nouveau PNJ

        </a>

    </div>

    {# =========================
       FLASH
       ========================= #}

    {% for label, messages in app.flashes %}

        {% for message in messages %}

            <div class="alert alert-{{ label == 'error' ? 'danger' : label }}
                        alert-dismissible fade show"
                 role="alert">

                {{ message }}

                <button type="button"
                        class="btn-close"
                        data-bs-dismiss="alert">
                </button>

            </div>

        {% endfor %}

    {% endfor %}

    {# =========================
       EMPTY
       ========================= #}

    {% if pnjs is empty %}

        <div class="rpg-empty text-center mt-5">

            Aucun PNJ rencontré pour le moment.

        </div>

    {% else %}

        <div class="row g-4">

            {% for pnj in pnjs %}

                <div class="col-md-6 col-lg-4">

                    <div class="card rpg-card h-100">

                        <div class="card-body d-flex flex-column">

                            {# =========================
                               NAME
                               ========================= #}

                            <h5 class="text-warning mb-2">

                                {{ pnj.name }}

                            </h5>

                            {# =========================
                               LOCALISATION
                               ========================= #}

                            <p class="text-secondary small mb-3">

                                📍 {{ pnj.localisation ?: 'Inconnue' }}

                            </p>

                            {# =========================
                               DESCRIPTION
                               ========================= #}

                            {% if pnj.description %}

                                <p class="mb-2">

                                    <strong>Description :</strong><br>

                                    {{ pnj.description|length > 120
                                        ? pnj.description|slice(0,120) ~ '...'
                                        : pnj.description }}

                                </p>

                            {% endif %}

                            {# =========================
                               PERSONNALITE
                               ========================= #}

                            {% if pnj.personnalite %}

                                <p class="mb-2">

                                    <strong>Personnalité :</strong><br>

                                    {{ pnj.personnalite|length > 100
                                        ? pnj.personnalite|slice(0,100) ~ '...'
                                        : pnj.personnalite }}

                                </p>

                            {% endif %}

                            {# =========================
                               COMPETENCE
                               ========================= #}

                            {% if pnj.competence %}

                                <p class="mb-2">

                                    <strong>Compétence :</strong><br>

                                    {{ pnj.competence|length > 100
                                        ? pnj.competence|slice(0,100) ~ '...'
                                        : pnj.competence }}

                                </p>

                            {% endif %}

                            {# =========================
                               NOTES
                               ========================= #}

                            {% if pnj.information %}

                                <p class="mb-3">

                                    <strong>Notes :</strong><br>

                                    {{ pnj.information|length > 100
                                        ? pnj.information|slice(0,100) ~ '...'
                                        : pnj.information }}

                                </p>

                            {% endif %}

                            {# =========================
                               ACTIONS
                               ========================= #}

                            <div class="mt-auto d-flex gap-2">

                                <a href="{{ path('pnj_edit', {
                                    id: pnj.id
                                }) }}"
                                   class="btn btn-outline-warning btn-sm w-100">

                                    ✏️ Modifier

                                </a>

                                <form method="POST"
                                      action="{{ path('pnj_delete', {
                                          id: pnj.id
                                      }) }}"
                                      class="w-100"
                                      onsubmit="return confirm('Supprimer ce PNJ ?')">

                                    <input type="hidden"
                                           name="_token"
                                           value="{{ csrf_token('delete' ~ pnj.id) }}">

                                    <button class="btn btn-outline-danger btn-sm w-100">

                                        🗑 Supprimer

                                    </button>

                                </form>

                            </div>

                        </div>

                    </div>

                </div>

            {% endfor %}

        </div>

    {% endif %}

</div>

{% endblock %}
```
