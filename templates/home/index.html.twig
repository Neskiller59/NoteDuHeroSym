{% extends 'base.html.twig' %}

{% block title %}Accueil{% endblock %}

{% block body %}
<div class="container mt-5">

    <h1 class="mb-4 text-center text-light">
        Bienvenue, {{ app.user.username }} ⚔️
    </h1>

    {# =========================
       FLASH MESSAGES
       ========================= #}
    {% for label, messages in app.flashes %}
        {% for message in messages %}
            <div class="alert alert-{{ label == 'error' ? 'danger' : label }} text-center">
                {{ message }}
            </div>
        {% endfor %}
    {% endfor %}

    {# =========================
       HERO GRID
       ========================= #}
    {% if heroes is defined and heroes|length > 0 %}

        <h2 class="mb-4 text-light">Vos héros</h2>

        <div class="row g-4">

            {% for hero in heroes %}

                <div class="col-md-4 col-lg-3">

                    <div class="hero-card
                        {% if selectedHero is defined and selectedHero and hero.id == selectedHero.id %}
                            selected
                        {% endif %}">

                        {# IMAGE SAFE #}
                        {% if hero.photo %}
                            <img src="{{ asset('uploads/' ~ hero.photo) }}"
                                 class="hero-img"
                                 alt="{{ hero.name }}">
                        {% else %}
                            <img src="{{ asset('images/default-hero.jpg') }}"
                                 class="hero-img"
                                 alt="default">
                        {% endif %}

                        <div class="hero-body">

                            <h5 class="hero-title">{{ hero.name }}</h5>

                            {% if hero.universe %}
                                <div class="hero-universe">
                                    {{ hero.universe }}
                                </div>
                            {% endif %}

                            {% if hero.additionalInfo %}
                                <p class="hero-desc">
                                    {{ hero.additionalInfo|length > 80
                                        ? hero.additionalInfo|slice(0,80) ~ '...'
                                        : hero.additionalInfo }}
                                </p>
                            {% endif %}

                            <div class="hero-actions">

                                <a href="{{ path('hero_index', {'hero_id': hero.id}) }}"
                                   class="btn btn-sm btn-gold">
                                    Sélectionner
                                </a>

                                <form action="{{ path('hero_delete', {'id': hero.id}) }}"
                                      method="post"
                                      onsubmit="return confirm('Supprimer ce héros ?');">

                                    <input type="hidden" name="_token"
                                           value="{{ csrf_token('delete' ~ hero.id) }}">

                                    <button class="btn btn-sm btn-danger-outline">
                                        Supprimer
                                    </button>

                                </form>

                            </div>

                        </div>

                    </div>

                </div>

            {% endfor %}

        </div>

    {% else %}
        <p class="text-center text-light mt-4">
            Aucun héros disponible.
        </p>
    {% endif %}

    {# =========================
       CREATE BUTTON
       ========================= #}
    <div class="text-center mt-5">
        <a href="{{ path('hero_new') }}" class="btn btn-create">
            + Créer un héros
        </a>
    </div>

    {# =========================
       SELECTED HERO
       ========================= #}
    {% if selectedHero is defined and selectedHero %}

        <div class="selected-hero mt-5 text-center">

            <h2>{{ selectedHero.name }}</h2>

            {% if selectedHero.photo %}
                <img src="{{ asset('uploads/' ~ selectedHero.photo) }}"
                     class="selected-img"
                     alt="{{ selectedHero.name }}">
            {% endif %}

            <p class="mt-2 text-muted">
                {{ selectedHero.universe }}
            </p>

        </div>

    {% endif %}

</div>

{# =========================
   PREMIUM STYLE
   ========================= #}
<style>

body {
    background: #414241;
    color: white;
}

/* CARD HERO */
.hero-card {
    background: linear-gradient(145deg, #1b1b2b, #12121f);
    border-radius: 16px;
    overflow: hidden;
    box-shadow: 0 0 15px rgba(0,0,0,0.5);
    transition: 0.3s ease;
}

.hero-card:hover {
    transform: translateY(-8px) scale(1.02);
    box-shadow: 0 0 25px rgba(255,215,0,0.2);
}

.hero-card.selected {
    border: 2px solid #ffd700;
    box-shadow: 0 0 30px rgba(255,215,0,0.4);
}

/* IMAGE */
.hero-img {
    width: 100%;
    height: 220px;
    object-fit: contain;
    background: radial-gradient(circle, #1f1f4e, #0f0f1a);
    padding: 12px;
}

/* BODY */
.hero-body {
    padding: 15px;
    text-align: center;
}

.hero-title {
    color: #ffd700;
    margin-bottom: 5px;
}

.hero-universe {
    font-size: 0.9rem;
    opacity: 0.8;
}

.hero-desc {
    font-size: 0.85rem;
    opacity: 0.7;
}

/* BUTTONS */
.btn-gold {
    background: #ffd700;
    color: #000;
    border: none;
}

.btn-gold:hover {
    background: #ffcc00;
}

.btn-danger-outline {
    border: 1px solid #ff4d4d;
    color: #ff4d4d;
    background: transparent;
}

.btn-danger-outline:hover {
    background: #ff4d4d;
    color: white;
}

.btn-create {
    background: linear-gradient(45deg, #ffd700, #ffcc00);
    color: #000;
    padding: 10px 25px;
    border-radius: 10px;
    font-weight: bold;
}

.btn-create:hover {
    transform: scale(1.05);
}

/* SELECTED HERO */
.selected-hero {
    margin-top: 40px;
}

.selected-img {
    width: 200px;
    height: 200px;
    object-fit: contain;
    background: #101016;
    padding: 10px;
    border-radius: 12px;
}

</style>

{% endblock %}