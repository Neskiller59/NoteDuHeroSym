{% extends 'base.html.twig' %}

{% block title %}Sélection du héros{% endblock %}

{% block body %}

<div class="container mt-5">

    <h1 class="text-center text-gold mb-5" id="hero-title">
        ⚔️ Sélectionnez votre héros
    </h1>

    {% if heroes|length > 0 %}

        <div class="row g-4">

            {% for hero in heroes %}

                <div class="col-md-6 col-lg-4">

                    <div class="hero-card shadow-lg">

                        {# IMAGE SAFE #}
                        {% if hero.photo %}
                            <img src="{{ asset('uploads/' ~ hero.photo) }}"
                                 class="hero-img"
                                 alt="{{ hero.name }}">
                        {% else %}
                            <img src="{{ asset('images/default-hero.jpg') }}"
                                 class="hero-img"
                                 alt="default hero">
                        {% endif %}

                        <div class="hero-body">

                            <h3 class="hero-name">
                                {{ hero.name }}
                            </h3>

                            <div class="hero-universe">
                                {{ hero.universe ?? 'Univers inconnu' }}
                            </div>

                            {% if hero.additionalInfo %}
                                <p class="hero-description">
                                    {{ hero.additionalInfo|length > 120
                                        ? hero.additionalInfo|slice(0,120) ~ '...'
                                        : hero.additionalInfo }}
                                </p>
                            {% endif %}

                            <div class="hero-actions">

                                {# ✔ SAFE FLOW : sélection + session #}
                                <a href="{{ path('hero_select', { id: hero.id }) }}"
                                   class="btn btn-select">
                                    Entrer dans le jeu
                                </a>

                                {# DELETE SAFE #}
                                <form method="POST"
                                      action="{{ path('hero_delete', { id: hero.id }) }}"
                                      onsubmit="return confirm('Supprimer ce héros ?')">

                                    <input type="hidden"
                                           name="_token"
                                           value="{{ csrf_token('delete' ~ hero.id) }}">

                                    <button class="btn btn-delete">
                                        Supprimer
                                    </button>

                                </form>

                            </div>

                        </div>

                    </div>

                </div>

            {% endfor %}

        </div>

    {% else %}

        <div class="empty-box">

            <h2>Aucun héros</h2>
            <p>Crée ton premier héros pour commencer l’aventure.</p>

        </div>

    {% endif %}

    <div class="text-center mt-5">

        <a href="{{ path('hero_new') }}"
           class="btn-create">
            + Créer un héros
        </a>

    </div>

</div>

<style>

body {
    background: radial-gradient(circle at top, #1f1f2e, #0d0d16);
    color: white;
}

.text-gold {
    color: #ffd700;
    text-shadow: 0 0 10px rgba(255,215,0,0.5);
}

.hero-card {
    background: linear-gradient(145deg, #23233a, #151522);
    border-radius: 18px;
    overflow: hidden;
    transition: 0.3s;
    border: 1px solid rgba(255,255,255,0.05);
}

.hero-card:hover {
    transform: translateY(-6px);
    box-shadow: 0 0 25px rgba(255,215,0,0.15);
}

.hero-img {
    width: 100%;
    height: 320px;
    object-fit: contain;
    background: radial-gradient(circle, #1b1b30, #101018);
    padding: 15px;
}

.hero-body {
    padding: 20px;
}

.hero-name {
    color: #ffd700;
}

.hero-universe {
    opacity: 0.7;
    margin-bottom: 10px;
}

.hero-actions {
    display: flex;
    gap: 10px;
    margin-top: 15px;
}

.btn-select {
    flex: 1;
    background: linear-gradient(45deg, #ffd700, #ffb700);
    color: black;
    border: none;
    padding: 10px;
    border-radius: 10px;
    text-decoration: none;
    font-weight: bold;
}

.btn-delete {
    background: transparent;
    border: 1px solid #ff4d4d;
    color: #ff4d4d;
    padding: 10px 15px;
    border-radius: 10px;
}

.btn-create {
    display: inline-block;
    padding: 14px 30px;
    border-radius: 12px;
    background: linear-gradient(45deg, #ffd700, #ffb700);
    color: black;
    font-weight: bold;
    text-decoration: none;
}


</style>

{% endblock %}